IgnoreUnknown UseKeychain

# Host-specific files are included before the global defaults because OpenSSH
# uses the first value it finds for most options.
Include ~/.ssh/config.d/*.conf

Host *
	AddKeysToAgent 1h
	ForwardAgent no
	HashKnownHosts yes
	IdentitiesOnly yes
	KbdInteractiveAuthentication no
	PasswordAuthentication no
	PubkeyAuthentication no
	StrictHostKeyChecking ask
	UpdateHostKeys yes
	UseKeychain yes
